{
  "name": "vue-i18n-llm-plugin",
  "version": "0.0.1",
  "description": "AI翻译：批量处理Vue中文（基于大模型）",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onCommand:vue-i18n-llm-plugin.translateAll"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vue-i18n-llm-plugin.translateAll",
        "title": "AI翻译：批量处理Vue中文（基于大模型）"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vue-i18n-llm-plugin.translateAll",
          "group": "z_commands",
          "when": "resourceExtname == .vue"
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^1.13.6",
    "fs-extra": "^11.3.4",
    "lodash": "^4.17.23"
  }
}
