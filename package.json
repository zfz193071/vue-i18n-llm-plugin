{
  "name": "vue-i18n-llm-plugin",
  "version": "0.0.1",
  "description": "AI翻译：批量处理Vue中文（基于大模型）",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onCommand:vue-i18n-llm-plugin.translateAll"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vue-i18n-llm-plugin.translateAll",
        "title": "AI翻译：批量处理Vue中文（基于大模型）"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vue-i18n-llm-plugin.translateAll",
          "group": "z_commands",
          "when": "resourceExtname == .vue"
        }
      ]
    },
    "configuration": {
      "title": "Vue i18n LLM",
      "properties": {
        "vueI18nLlm.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI 兼容 Chat Completions 的 API Key。也可设置环境变量 VUE_I18N_LLM_API_KEY。"
        },
        "vueI18nLlm.baseUrl": {
          "type": "string",
          "default": "",
          "description": "可选。覆盖默认网关地址；留空则使用内置默认或环境变量 VUE_I18N_LLM_BASE_URL。"
        },
        "vueI18nLlm.model": {
          "type": "string",
          "default": "",
          "description": "可选。覆盖模型名；留空则使用内置默认或环境变量 VUE_I18N_LLM_MODEL。"
        }
      }
    }
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "axios": "^1.13.6",
    "fs-extra": "^11.3.4",
    "lodash": "^4.17.23"
  }
}
